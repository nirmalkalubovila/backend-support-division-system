# ──────────────────────────────────────────────────────────────
# Prologics Support Division System — Backend Environment
# ──────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URL=mongodb://localhost:27017/support-division-system

# JWT
JWT_SECRET=your-jwt-secret-change-me-in-production
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30

# Logging
LOG_LEVEL=debug

# Super Admin Seed Credentials
SUPER_ADMIN_EMAIL=admin@prologics.lk
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_NAME=Super Admin

# Email (Free SMTP — use Gmail App Password or Ethereal for development)
# For Gmail: enable 2FA, then generate an App Password at https://myaccount.google.com/apppasswords
# For Ethereal (free testing): create account at https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USERNAME=your-ethereal-username@ethereal.email
SMTP_PASSWORD=your-ethereal-password
EMAIL_FROM=support@prologics.lk

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
